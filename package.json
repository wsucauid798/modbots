{
  "name": "modbots",
  "private": true,
  "version": "0.0.1-alpha",
  "workspaces": [
    "modbots-backend",
    "apps/chat-bot-runtime"
  ],
  "scripts": {
    "dev:api": "npm run dev --workspace modbots-backend",
    "build:api": "npm run build --workspace modbots-backend",
    "build:realtime": "cargo build --manifest-path modbots-backend/realtime-gateway/Cargo.toml",
    "smoke:activity": "npm run smoke:activity --workspace modbots-backend",
    "start:api": "npm run start --workspace modbots-backend",
    "test:api": "npm run test --workspace modbots-backend",
    "test:realtime": "cargo test --manifest-path modbots-backend/realtime-gateway/Cargo.toml",
    "seed:bots": "npm run seed:bots --workspace modbots-backend",
    "dev:bots": "npm run dev --workspace apps/chat-bot-runtime",
    "build:bots": "npm run build --workspace apps/chat-bot-runtime"
  }
}
