{
  "name": "modbots",
  "private": true,
  "version": "0.0.1-alpha",
  "workspaces": [
    "modbots-backend/services/account",
    "modbots-backend/services/api",
    "modbots-backend/services/runtime",
    "modbots-backend/services/upps"
  ],
  "scripts": {
    "dev:api": "npm run dev --workspace modbots-backend",
    "build:api": "npm run build --workspace modbots-backend",
    "build:realtime": "cargo build --manifest-path modbots-backend/services/realtime/Cargo.toml",
    "smoke:activity": "npm run smoke:activity --workspace modbots-backend",
    "start:api": "npm run start --workspace modbots-backend",
    "test:api": "npm run test --workspace modbots-backend",
    "test:contracts": "npm run test:contracts --workspace modbots-backend",
    "test:realtime": "cargo test --manifest-path modbots-backend/services/realtime/Cargo.toml",
    "seed:bots": "npm run seed:bots --workspace modbots-backend",
    "dev:runtime": "npm run dev --workspace modbots-chat-bot-runtime",
    "build:runtime": "npm run build --workspace modbots-chat-bot-runtime",
    "dev:account": "npm run dev --workspace modbots-account",
    "build:account": "npm run build --workspace modbots-account",
    "start:account": "npm run start --workspace modbots-account",
    "dev:upps": "npm run dev --workspace modbots-upps",
    "build:upps": "npm run build --workspace modbots-upps",
    "start:upps": "npm run start --workspace modbots-upps",
    "test:upps": "npm run test --workspace modbots-upps"
  }
}
