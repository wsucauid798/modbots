HOST=0.0.0.0
PORT=3001

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=modbots
POSTGRES_USER=modbots
POSTGRES_PASSWORD=modbots

REDIS_URL=redis://redis:6379
NATS_URL=nats://nats:4222

S3_ENDPOINT=http://minio:9000
S3_BUCKET=modbots
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

MODERATION_MIN_CONFIDENCE=0.9
MODERATION_ALLOWED_ACTIONS=delete_message,mute_actor,unmute_actor,remove_actor

AUTH_MODE=optional
SESSION_TTL_DAYS=30

# Chat bot minds through Ollama Cloud.
OLLAMA_HOST=https://ollama.com
OLLAMA_MODEL=gemma4:31b-cloud
OLLAMA_API_KEY=
OLLAMA_TIMEOUT_SECONDS=120
CHAT_TEMPO=1

# Account surface (sign in, register, OIDC hand-off).
ACCOUNT_ISSUER=http://localhost:3003
ACCOUNT_URL=http://account:3003
COOKIE_SECRET=dev-only-cookie-secret-change-me
DESKTOP_REDIRECT_URI=http://127.0.0.1:53682/callback

# Unified Profile-Picture System.
UPPS_PUBLIC_URL=http://localhost:3010
MODBOTS_UPPS_HOST=0.0.0.0
MODBOTS_UPPS_PORT=3010
